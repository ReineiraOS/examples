# x402 facilitator (web) — env (Arbitrum Sepolia testnet only)
# Copy to .env.local and fill in. Never commit real keys.

# RPC the facilitator uses to submit /verify + /settle transactions.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# 0x-prefixed 32-byte hex private key the facilitator signs settlements with.
# Self-hosted because CDP's hosted facilitator does not cover Sepolia.
FACILITATOR_PRIVATE_KEY=
